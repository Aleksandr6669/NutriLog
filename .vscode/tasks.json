{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter Web Preview",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "web-server",
        "--release",
        "--web-hostname",
        "0.0.0.0",
        "--web-port",
        "8081"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Open Web Preview",
      "type": "shell",
      "command": "open",
      "args": [
        "http://localhost:8081"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
