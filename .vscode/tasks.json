{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto: Flutter Web Preview",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "web-server",
        "--release",
        "--web-hostname",
        "0.0.0.0",
        "--web-port",
        "8080"
      ],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
