rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/appData/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /publicRecipes/{recipeId} {
      // Любой авторизованный пользователь может читать публичные рецепты
      allow read: if request.auth != null;
      // Только автор может создавать и обновлять свой рецепт
      allow create, update: if request.auth != null
                            && request.resource.data.userId == request.auth.uid;
      // Только автор может удалять свой рецепт
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
    match /donatedRecipes/{recipeId} {
      // Любой авторизованный пользователь может читать
      allow read: if request.auth != null;
      // Только создание — никто не может обновить или удалить (даже автор)
      allow create: if request.auth != null
                    && request.resource.data.donatedBy == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
