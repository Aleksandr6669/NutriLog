<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="16dp"
    android:elevation="6dp"
    android:clipToPadding="false"
    android:gravity="center_horizontal">

    <!-- Круглый прогресс воды, крупное число -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_circle_widget">
        <ProgressBar
            android:id="@+id/progressWater"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_circle_water"
            android:rotation="-90"
            android:layout_gravity="center" />
        <TextView
            android:id="@+id/widgetWater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0 / 0 мл"
            android:textColor="#16261B"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp" />
    </FrameLayout>
</LinearLayout>
