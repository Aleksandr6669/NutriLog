<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Top: Calories -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:padding="12dp"
        android:layout_marginBottom="8dp">
        
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#1DB954" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КАЛОРИИ СЕГОДНЯ"
                android:textColor="#1DB954"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widgetCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1450"
                android:textColor="#16261B"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Middle: Water -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:padding="8dp"
        android:layout_marginBottom="8dp">
        <View android:layout_width="4dp" android:layout_height="match_parent" android:background="#1DB954" />
        <TextView android:text="ВОДА: " android:textColor="#1DB954" android:textSize="12sp" android:layout_marginStart="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/widgetWater" android:text="1.2 Л" android:textColor="#16261B" android:textSize="12sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Bottom: Steps -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:padding="8dp">
        <View android:layout_width="4dp" android:layout_height="match_parent" android:background="#1DB954" />
        <TextView android:text="ШАГИ: " android:textColor="#1DB954" android:textSize="12sp" android:layout_marginStart="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/widgetSteps" android:text="6500" android:textColor="#16261B" android:textSize="12sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>

</LinearLayout>
