<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Top Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="12"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:layout_marginBottom="8dp">
        <View android:layout_width="4dp" android:layout_height="match_parent" android:background="#1DB954" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="12dp">
            <TextView android:text="ОБЗОР ДНЯ" android:textColor="#1DB954" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/widgetCalories" android:text="1840 ккал" android:textColor="#16261B" android:textSize="28sp" android:textStyle="bold" />
            <TextView android:text="До цели осталось 450" android:textColor="#8E998F" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mid Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="10"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:layout_marginBottom="8dp">
        <View android:layout_width="4dp" android:layout_height="match_parent" android:background="#1DB954" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="92г" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:text="Белки" android:textColor="#1DB954" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="58г" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:text="Жиры" android:textColor="#1DB954" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="210г" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:text="Углев" android:textColor="#1DB954" android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Card -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="8" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F1F8F4" android:layout_marginEnd="4dp">
             <View android:layout_width="3dp" android:layout_height="match_parent" android:background="#1DB954" />
             <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp">
                 <TextView android:text="ВОДА" android:textColor="#1DB954" android:textSize="8sp" />
                 <TextView android:id="@+id/widgetWater" android:text="1.2 Л" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" />
             </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F1F8F4">
             <View android:layout_width="3dp" android:layout_height="match_parent" android:background="#1DB954" />
             <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp">
                 <TextView android:text="ШАГИ" android:textColor="#1DB954" android:textSize="8sp" />
                 <TextView android:id="@+id/widgetSteps" android:text="6 450" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" />
             </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
