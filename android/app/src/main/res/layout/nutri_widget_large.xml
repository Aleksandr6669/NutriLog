<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="16dp"
    android:elevation="6dp"
    android:clipToPadding="false"
    android:gravity="center_horizontal">

    <!-- Круглый прогресс-бар калорий -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_circle_widget">
        <ProgressBar
            android:id="@+id/progressCalories"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_circle_calories"
            android:rotation="-90"
            android:layout_gravity="center" />
        <TextView
            android:id="@+id/widgetCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1800"
            android:textColor="#16261B"
            android:textSize="44sp"
            android:textStyle="bold"
            android:layout_gravity="center" />
        <TextView
            android:id="@+id/widgetCaloriesSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="осталось ккал"
            android:textColor="#B0B0B0"
            android:textSize="15sp"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="32dp" />

        <!-- Для совместимости с Kotlin-кодом -->
        <TextView
            android:id="@+id/widgetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <TextView
            android:id="@+id/widgetMainValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <TextView
            android:id="@+id/widgetSubValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <TextView
            android:id="@+id/widgetMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
        <TextView
            android:id="@+id/widgetMacros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Блок ККал, Актив, Цель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_food"
                android:tint="#1DB954" />
            <TextView
                android:id="@+id/tvCalories"
                android:text="0"
                android:textColor="#16261B"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:text="ККал"
                android:textColor="#B0B0B0"
                android:textSize="13sp" />
        </LinearLayout>
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#E0E0E0" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_activity"
                android:tint="#FFB300" />
            <TextView
                android:id="@+id/tvActivity"
                android:text="0"
                android:textColor="#16261B"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:text="Актив"
                android:textColor="#B0B0B0"
                android:textSize="13sp" />
        </LinearLayout>
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#E0E0E0" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_goal"
                android:tint="#4FC3F7" />
            <TextView
                android:id="@+id/tvGoal"
                android:text="1800"
                android:textColor="#16261B"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:text="Цель"
                android:textColor="#B0B0B0"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Карточки нутриентов -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">
        <!-- Углеводы -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:text="Углеводы"
                android:textColor="#1DB954"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressCarbs"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_carbs"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvCarbsPercent"
                android:text="0%"
                android:textColor="#1DB954"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/tvCarbs"
                android:text="0г / 195г"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <!-- Белки -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:text="Белки"
                android:textColor="#FFB300"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressProtein"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_protein"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvProteinPercent"
                android:text="0%"
                android:textColor="#FFB300"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/tvProtein"
                android:text="0г / 120г"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <!-- Жиры -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp">
            <TextView
                android:text="Жиры"
                android:textColor="#4FC3F7"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressFat"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_fat"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvFatPercent"
                android:text="0%"
                android:textColor="#4FC3F7"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/tvFat"
                android:text="0г / 60г"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Блок нутриентов и воды в карточках -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">
        <!-- Нутриенты -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- Углеводы -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_widget"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:text="Углеводы"
                    android:textColor="#1DB954"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressCarbs"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_carbs"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:id="@+id/tvCarbs"
                    android:text="0г / 0г"
                    android:textColor="#16261B"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <!-- Белки -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_widget"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:text="Белки"
                    android:textColor="#FFB300"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressProtein"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_protein"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:id="@+id/tvProtein"
                    android:text="0г / 0г"
                    android:textColor="#16261B"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <!-- Жиры -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_widget"
                android:padding="10dp">
                <TextView
                    android:text="Жиры"
                    android:textColor="#4FC3F7"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressFat"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_fat"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:id="@+id/tvFat"
                    android:text="0г / 0г"
                    android:textColor="#16261B"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
        <!-- Вода -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp"
            android:gravity="center">
            <TextView
                android:text="Вода"
                android:textColor="#00BFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressWater"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="40dp"
                android:layout_height="120dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_water"
                android:rotation="-90"
                android:layout_gravity="center"
                android:layout_marginTop="8dp" />
            <TextView
                android:id="@+id/tvWater"
                android:text="0мл / 0мл"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Блок нутриентов -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:text="Углеводы"
                android:textColor="#1DB954"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressCarbs"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_carbs"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvCarbs"
                android:text="0г / 0г"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:text="Белки"
                android:textColor="#FFB300"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressProtein"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_protein"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvProtein"
                android:text="0г / 0г"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="10dp">
            <TextView
                android:text="Жиры"
                android:textColor="#4FC3F7"
                android:textSize="13sp"
                android:textStyle="bold" />
            <ProgressBar
                android:id="@+id/progressFat"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_fat"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvFat"
                android:text="0г / 0г"
                android:textColor="#16261B"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
