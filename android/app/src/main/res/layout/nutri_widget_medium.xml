<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Левая часть: Калории -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_circle_widget">
        <ProgressBar
            android:id="@+id/progressCalories"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_circle_calories"
            android:rotation="-90"
            android:layout_gravity="center" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">
            <TextView
                android:id="@+id/widgetCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1800"
                android:textColor="#16261B"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widgetCaloriesSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="осталось"
                android:textColor="#707070"
                android:textSize="10sp" />
        </LinearLayout>
    </FrameLayout>

    <View
        android:layout_width="12dp"
        android:layout_height="match_parent" />

    <!-- Правая часть: Макросы и данные -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:text="Цель"
                    android:textColor="#B0B0B0"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvGoal"
                    android:text="2200"
                    android:textColor="#16261B"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:text="Съедено"
                    android:textColor="#B0B0B0"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvCalories"
                    android:text="400"
                    android:textColor="#1DB954"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Полоски макросов -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_widget"
            android:padding="8dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="Б"
                    android:textColor="#FFB300"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressProtein"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="6dp"
                    android:progressDrawable="@drawable/progress_bar_protein" />
                <TextView
                    android:id="@+id/tvProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40/120г"
                    android:textColor="#16261B"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="Ж"
                    android:textColor="#4FC3F7"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressFat"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="6dp"
                    android:progressDrawable="@drawable/progress_bar_fat" />
                <TextView
                    android:id="@+id/tvFat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15/60г"
                    android:textColor="#16261B"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="У"
                    android:textColor="#1DB954"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressCarbs"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="6dp"
                    android:progressDrawable="@drawable/progress_bar_carbs" />
                <TextView
                    android:id="@+id/tvCarbs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100/200г"
                    android:textColor="#16261B"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
