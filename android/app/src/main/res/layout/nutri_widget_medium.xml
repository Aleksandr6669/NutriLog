<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="8dp">

    <!-- Left: Primary Stats -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:background="#F1F8F4"
        android:padding="8dp"
        android:gravity="center"
        android:layout_marginEnd="4dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КАЛОРИИ"
            android:textColor="#1DB954"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widgetCalories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1450"
            android:textColor="#16261B"
            android:textSize="26sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="осталось сегодня"
            android:textColor="#8E998F"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Right: Macro Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.8"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:padding="4dp"
        android:gravity="center">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/widgetProteins" android:text="85г" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="Белки" android:textColor="#1DB954" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/widgetFats" android:text="45г" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="Жиры" android:textColor="#1DB954" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/widgetCarbs" android:text="120г" android:textColor="#16261B" android:textSize="14sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="Углев" android:textColor="#1DB954" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
