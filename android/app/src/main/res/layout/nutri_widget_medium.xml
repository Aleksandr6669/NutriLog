<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Left Card: Calories -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:layout_marginEnd="8dp">
        
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#1DB954" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КАЛОРИИ"
                android:textColor="#1DB954"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/widgetCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1450"
                android:textColor="#16261B"
                android:textSize="28sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ккал за сегодня"
                android:textColor="#8E998F"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Right Card: Macro (УБЖ) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="#F1F8F4">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#1DB954" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center">

            <!-- Proteins -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:text="Белки"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="#8E998F"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widgetProteins"
                    android:text="85г"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#16261B"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Fats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:text="Жиры"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="#8E998F"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widgetFats"
                    android:text="45г"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#16261B"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Carbs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:text="Углев"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="#8E998F"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widgetCarbs"
                    android:text="120г"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#16261B"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
