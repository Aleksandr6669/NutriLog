<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="8dp">

    <!-- Calories Block -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:background="#F1F8F4"
        android:padding="8dp"
        android:gravity="center"
        android:layout_marginBottom="4dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КАЛОРИИ"
            android:textColor="#1DB954"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetCalories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1450"
            android:textColor="#16261B"
            android:textSize="20sp"
            android:textStyle="bold" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="осталось"
            android:textColor="#8E998F"
            android:textSize="8sp" />
    </LinearLayout>

    <!-- Macros Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:padding="4dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:text="85" android:textColor="#16261B" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="Б" android:textColor="#1DB954" android:textSize="8sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:text="45" android:textColor="#16261B" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="Ж" android:textColor="#1DB954" android:textSize="8sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:text="120" android:textColor="#16261B" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="У" android:textColor="#1DB954" android:textSize="8sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
