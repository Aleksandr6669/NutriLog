<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Card 1: Calories -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="#F1F8F4"
        android:layout_marginBottom="8dp">
        
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#1DB954" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КАЛОРИИ"
                android:textColor="#1DB954"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1450"
                android:textColor="#16261B"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Card 2: Macro (УБЖ) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="#F1F8F4">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#1DB954" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="4dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="85г" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#16261B" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:text="Белки" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#1DB954" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="45г" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#16261B" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:text="Жиры" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#1DB954" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="120г" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#16261B" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:text="Углев" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#1DB954" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
